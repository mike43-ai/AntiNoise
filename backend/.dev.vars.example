# Copy to .dev.vars for local `wrangler dev`. NEVER commit .dev.vars.
# Production secrets are set via `wrangler secret put <NAME>`.

OPENROUTER_API_KEY=your-openrouter-key-here
# Paste the entire service account JSON on one line (escape inner quotes and
# replace literal newlines in private_key with \n).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
REVENUECAT_WEBHOOK_AUTH=your-rc-webhook-shared-secret
